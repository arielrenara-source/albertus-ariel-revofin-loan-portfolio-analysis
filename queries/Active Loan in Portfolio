-- Loan yang masih aktif dalam portfolio
SELECT
  loan_status,
  COUNT(*)            AS loan_count,
  SUM(funded_amount)  AS total_os
FROM `nextproject-001.FIP.loan`
WHERE loan_status IN (
  'Current',
  'In Grace Period',
  'Late (16-30 days)',
  'Late (31-120 days)',
  'Default'
)
GROUP BY loan_status
ORDER BY loan_count DESC;
